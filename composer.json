{
  "name": "eslam-reda-div/filament-copilot",
  "description": "A Filament plugin for AI-powered copilot features.",
  "keywords": [
    "filament",
    "laravel",
    "copilot",
    "plugin"
  ],
  "homepage": "https://github.com/eslam-reda-div/filament-copilot",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": "^8.2",
    "filament/filament": "^5.0",
    "laravel/ai": "^0.4.0 || ^0.5.0 || ^0.6.0",
    "laravel/prompts": "^0.3.14",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "laravel/pint": "^1.28",
    "nunomaduro/collision": "^8.0",
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "EslamRedaDiv\\FilamentCopilot\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EslamRedaDiv\\FilamentCopilot\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "EslamRedaDiv\\FilamentCopilot\\FilamentCopilotServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
